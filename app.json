{
  "expo": {
    "name": "LunaFlow",
    "slug": "LunaFlow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/favicon.png",
    "scheme": "lunaflow",
    "userInterfaceStyle": "light",

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF7FA",
        "foregroundImage": "./assets/images/lunaflow_core_app_icon.png",
        "backgroundImage": "./assets/images/lunaflow_core_app_icon.png",
        "monochromeImage": "./assets/images/lunaflow_core_app_icon.png"
      },
      "package": "com.blitzbugg.lunaflow"
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",

      [
        "expo-splash-screen",
        {
          "image": "./assets/images/favicon.png",
          "imageWidth": 220,
          "resizeMode": "contain",

          "backgroundColor": "#FFF7FA",

          "dark": {
            "backgroundColor": "#FCE4EC"
          }
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "313cdee1-c689-4ab3-b2f8-deb3d5793fc0"
      }
    }
  }
}